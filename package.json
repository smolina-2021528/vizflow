{
  "name": "vizflow-monorepo",
  "version": "0.0.1",
  "private": true,
  "description": "VizFlow.js monorepo — charts, tables and CLI wizard",
  "scripts": {
    "dev": "pnpm --filter @vizflow/core dev",
    "build": "pnpm --filter @vizflow/core build && pnpm --filter @vizflow/cli build",
    "test": "pnpm --filter @vizflow/core test && pnpm --filter @vizflow/cli test",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  }
}
